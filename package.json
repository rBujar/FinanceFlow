{
  "name": "financeflow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node build-html.js",
    "build:assets": "vite build",
    "build:html": "node build-html.js",
    "preview": "vite preview",
    "php": "php -S localhost:8000",
    "dev:all": "concurrently \"npm run dev\" \"npm run php\"",
    "deploy": "npm run build && netlify deploy --prod --dir=dist",
    "deploy:preview": "npm run build && netlify deploy --dir=dist"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "sass": "^1.99.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "swiper": "^12.2.0"
  }
}
